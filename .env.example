# Copy this file to .env and fill in a real secret before starting the server.
# Generate one with:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-me-to-a-long-random-string

# Port the HTTP server listens on (default 3000)
PORT=3000

# Database connection (libSQL). Leave both unset for local development —
# the server falls back to a local file (data.db) in the project root.
#
# For persistent storage in production (e.g. on Render's free tier, whose
# disk is wiped on restart/redeploy), point these at a free Turso database:
#   DATABASE_URL=libsql://your-db-name-your-org.turso.io
#   DATABASE_AUTH_TOKEN=eyJ...
# DATABASE_URL=
# DATABASE_AUTH_TOKEN=
